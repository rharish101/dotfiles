{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "agent": {
    "build": { "color": "secondary", "variant": "" },
    "plan": { "color": "accent", "variant": "thinking" },
  },
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "cargo check *": "allow",
      "cargo clippy *": "allow",
      "cargo doc *": "allow",
      "cargo metadata *": "allow",
      "cargo search *": "allow",
      "cargo tree *": "allow",
      "cat *": "allow",
      "cat *.env": "deny",
      "cat *.env.*": "deny",
      "cat *.env.example": "allow",
      "echo *": "allow",
      "find *": "allow",
      "git diff *": "allow",
      "git grep *": "allow",
      "git log *": "allow",
      "git ls-tree *": "allow",
      "git rev-parse *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "man *": "allow",
      "rg *": "allow",
      "sort *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "which *": "allow",
    },
    "external_directory": {
      "~/.cargo/src/registry/**": "allow",
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "question": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
    },
    "skill": "allow",
    "task": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
  },
  "lsp": {
    "ruff": { "command": ["ruff", "server"], "extensions": [".py", ".pyi"] },
    "ty": { "command": ["ty", "server"], "extensions": [".py", ".pyi"] },
  },
  "formatter": {
    "ruff": {
      "command": ["ruff", "check", "--fix", "--unfixable", "F401"],
      "extensions": [".py", ".pyi"],
    },
    "ruff_format": {
      "command": ["ruff", "format"],
      "extensions": [".py", ".pyi"],
    },
  },
}
