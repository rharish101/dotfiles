{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "agent": {
    "explore": { "mode": "all" },
  },
  "permission": {
    "*": "ask",
    "glob": "allow",
    "list": "allow",
    "task": "allow",
    "lsp": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
  },
  "lsp": {
    "ruff": {
      "command": ["ruff", "server"],
      "extensions": [".py", ".pyi"],
    },
    "ty": {
      "command": ["ty", "server"],
      "extensions": [".py", ".pyi"],
    },
  },
}
