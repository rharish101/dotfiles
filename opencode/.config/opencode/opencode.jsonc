{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "enabled_providers": ["llama_cpp"],
  "model": "llama_cpp/Qwen-3.6-27B",
  "small_model": "llama_cpp/Qwen-3.6-27B",
  "provider": {
    "llama_cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp",
      "options": { "baseURL": "http://localhost:8080" },
      "models": {
        "Qwen-3.6-27B": {
          "name": "Qwen 3.6 (27B)",
          "options": {
            "temperature": 0.7,
            "top_p": 0.8,
            "top_k": 20,
            "min_p": 0.0,
            "presence_penalty": 1.5,
            "repeat_penalty": 1.0,
            "thinking_budget_tokens": 0,
          },
          "variants": {
            "thinking": {
              "temperature": 0.6,
              "top_p": 0.95,
              "top_k": 20,
              "min_p": 0.0,
              "presence_penalty": 0.0,
              "repeat_penalty": 1.0,
              "thinking_budget_tokens": -1,
            },
          },
        },
      },
    },
  },
  "agent": {
    "build": { "color": "secondary", "variant": "" },
    "plan": { "color": "accent", "variant": "thinking" },
    "explore": { "variant": "", "permission": { "task": "deny" } },
  },
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "cargo check *": "allow",
      "cargo clippy *": "allow",
      "cargo doc *": "allow",
      "cargo metadata *": "allow",
      "cargo search *": "allow",
      "cargo tree *": "allow",
      "cat *": "allow",
      "cat *.env": "deny",
      "cat *.env.*": "deny",
      "cat *.env.example": "allow",
      "echo *": "allow",
      "find *": "allow",
      "git diff *": "allow",
      "git grep *": "allow",
      "git log *": "allow",
      "git ls-tree *": "allow",
      "git rev-parse *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "man *": "allow",
      "rg *": "allow",
      "sort *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "which *": "allow",
    },
    "external_directory": {
      "~/.cargo/src/registry/**": "allow",
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "question": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
    },
    "skill": "allow",
    "task": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
  },
  "lsp": {
    "ruff": { "command": ["ruff", "server"], "extensions": [".py", ".pyi"] },
    "ty": { "command": ["ty", "server"], "extensions": [".py", ".pyi"] },
  },
  "formatter": {
    "ruff": {
      "command": ["ruff", "check", "--fix", "--unfixable", "F401"],
      "extensions": [".py", ".pyi"],
    },
    "ruff_format": {
      "command": ["ruff", "format"],
      "extensions": [".py", ".pyi"],
    },
  },
}
